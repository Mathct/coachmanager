{% extends 'base.html.twig' %}

{% block title %}Joueur | CoachManager{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="cm-page-title">{{ player.nom }} {{ player.prenom }}</h1>
            <p class="cm-page-subtitle">Fiche joueur</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_player_index') }}" class="btn btn-outline-light">Retour</a>
            <a href="{{ path('app_player_edit', {'id': player.id}) }}" class="btn btn-primary">Modifier</a>
        </div>
    </div>

    <div class="cm-card p-4">
        <div class="row g-3">
            <div class="col-md-4"><div class="cm-stat"><p class="cm-soft mb-1">Sexe</p><p class="h4 mb-0">{{ player.sexe }}</p></div></div>
            <div class="col-md-4"><div class="cm-stat"><p class="cm-soft mb-1">Naissance</p><p class="h6 mb-0">{{ player.dateNaissance ? player.dateNaissance|date('d/m/Y') : '-' }}</p></div></div>
            <div class="col-md-4"><div class="cm-stat"><p class="cm-soft mb-1">Equipe</p><p class="h6 mb-0">{{ player.team ? player.team.nom : 'Sans equipe' }}</p></div></div>
        </div>
        <div class="mt-4 pt-3 border-top border-secondary-subtle">
            {{ include('player/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
