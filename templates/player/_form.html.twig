{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-6">
            {{ form_row(form.nom) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.prenom) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.date_naissance) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.sexe) }}
        </div>
        <div class="col-12">
            {{ form_row(form.team) }}
        </div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-success">{{ button_label|default('Enregistrer') }}</button>
        <a href="{{ path('app_player_index') }}" class="btn btn-outline-light">Annuler</a>
    </div>
{{ form_end(form) }}
