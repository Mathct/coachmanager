{{ form_start(form) }}
    <div class="row g-3 cm-player-form">
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control cm-input'}}) }}
                {{ form_errors(form.nom) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.prenom) }}
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control cm-input'}}) }}
                {{ form_errors(form.prenom) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.date_naissance) }}
                {{ form_widget(form.date_naissance, {'attr': {'class': 'form-control cm-input'}}) }}
                {{ form_errors(form.date_naissance) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.sexe) }}
                {{ form_widget(form.sexe, {'attr': {'class': 'form-control cm-input'}}) }}
                {{ form_errors(form.sexe) }}
            </div>
        </div>
        <div class="col-12">
            <div class="mb-3">
                {{ form_label(form.team) }}
                {{ form_widget(form.team, {'attr': {'class': 'form-control cm-input'}}) }}
                {{ form_errors(form.team) }}
            </div>
        </div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-success">{{ button_label|default('Enregistrer') }}</button>
        <a href="{{ path('app_player_index') }}" class="btn btn-outline-light">Annuler</a>
    </div>
{{ form_end(form) }}
