<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}CoachManager{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        {% block stylesheets %}
            <style>
                :root {
                    --cm-bg: #0b1020;
                    --cm-surface: #111a33;
                    --cm-surface-soft: #172449;
                    --cm-primary: #13c39c;
                    --cm-secondary: #2d7cf6;
                    --cm-text: #e8eefc;
                    --cm-muted: #98a9d0;
                    --cm-border: #24325f;
                }

                body {
                    background: radial-gradient(circle at 20% 5%, #152758 0%, var(--cm-bg) 42%);
                    min-height: 100vh;
                    color: var(--cm-text);
                }

                .cm-navbar {
                    background: rgba(11, 16, 32, 0.85);
                    border-bottom: 1px solid var(--cm-border);
                    backdrop-filter: blur(8px);
                }

                .cm-brand {
                    font-weight: 700;
                    letter-spacing: 0.4px;
                }

                .cm-brand-mark {
                    color: var(--cm-primary);
                }

                .cm-card {
                    background: linear-gradient(180deg, var(--cm-surface) 0%, var(--cm-surface-soft) 100%);
                    border: 1px solid var(--cm-border);
                    border-radius: 16px;
                    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.28);
                }

                .cm-page-title {
                    font-weight: 700;
                    margin-bottom: 0.3rem;
                }

                .cm-page-subtitle {
                    color: var(--cm-muted);
                    margin-bottom: 0;
                }

                .cm-table thead th {
                    background-color: rgba(45, 124, 246, 0.15);
                    color: #bdd7ff;
                    border-bottom-color: var(--cm-border);
                }

                .cm-table td,
                .cm-table th {
                    border-color: var(--cm-border);
                    vertical-align: middle;
                }

                .cm-stat {
                    border: 1px solid var(--cm-border);
                    border-radius: 14px;
                    background: rgba(23, 36, 73, 0.8);
                    padding: 1rem;
                }

                .cm-stat-value {
                    font-size: 1.8rem;
                    font-weight: 800;
                    line-height: 1.1;
                }

                .cm-soft {
                    color: var(--cm-muted);
                }

                .btn-primary {
                    background-color: var(--cm-secondary);
                    border-color: var(--cm-secondary);
                }

                .btn-success {
                    background-color: var(--cm-primary);
                    border-color: var(--cm-primary);
                    color: #05101f;
                    font-weight: 600;
                }

                .btn-outline-light {
                    border-color: #6d84bc;
                    color: #d7e2ff;
                }

                .form-control,
                .form-select {
                    background-color: #0f1934;
                    border-color: #334c8d;
                    color: #eef4ff;
                }

                .form-control:focus,
                .form-select:focus {
                    background-color: #0f1934;
                    color: #eef4ff;
                }

                .form-label {
                    color: #c5d5f7;
                    font-weight: 600;
                }

                .text-muted {
                    color: var(--cm-muted) !important;
                }

                .cm-pitch {
                    position: relative;
                    width: 100%;
                    min-height: 520px;
                    border-radius: 16px;
                    border: 2px solid #8cd08f;
                    background: linear-gradient(180deg, #1f7b42 0%, #19663a 100%);
                    overflow: hidden;
                }

                .cm-pitch-sm {
                    min-height: 360px;
                }

                .cm-pitch::before {
                    content: '';
                    position: absolute;
                    inset: 0;
                    background: repeating-linear-gradient(
                        180deg,
                        rgba(255, 255, 255, 0.06) 0px,
                        rgba(255, 255, 255, 0.06) 36px,
                        rgba(255, 255, 255, 0) 36px,
                        rgba(255, 255, 255, 0) 72px
                    );
                }

                .cm-pitch-center-line {
                    position: absolute;
                    left: 0;
                    right: 0;
                    top: 0;
                    border-top: 2px solid rgba(255, 255, 255, 0.75);
                    z-index: 1;
                }

                .cm-pitch-center-circle {
                    position: absolute;
                    width: 140px;
                    height: 70px;
                    border: 2px solid rgba(255, 255, 255, 0.75);
                    border-top: none;
                    border-radius: 0 0 70px 70px;
                    left: calc(50% - 70px);
                    top: 0;
                    z-index: 1;
                }

                .cm-pitch-box {
                    position: absolute;
                    width: 55%;
                    left: 22.5%;
                    height: 120px;
                    border: 2px solid rgba(255, 255, 255, 0.75);
                    z-index: 1;
                }

                .cm-pitch-box-top {
                    display: none;
                }

                .cm-pitch-box-bottom {
                    bottom: 0;
                    border-bottom: none;
                }

                .cm-pitch-board {
                    position: absolute;
                    inset: 0;
                    z-index: 2;
                }

                .cm-slot-layer,
                .cm-player-layer {
                    position: absolute;
                    inset: 0;
                }

                .cm-slot-layer {
                    z-index: 1;
                }

                .cm-player-layer {
                    z-index: 2;
                }

                .cm-slot-marker {
                    position: absolute;
                    transform: translate(-50%, -50%);
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 0.2rem;
                }

                .cm-slot-marker-dot {
                    width: 14px;
                    height: 14px;
                    border-radius: 50%;
                    border: 2px dashed rgba(214, 239, 222, 0.95);
                    background: rgba(11, 39, 19, 0.38);
                    box-shadow: 0 0 0 3px rgba(224, 247, 230, 0.18);
                }

                .cm-slot-marker-label {
                    color: #e4ffe8;
                    font-size: 0.62rem;
                    letter-spacing: 0.03em;
                    font-weight: 700;
                    background: rgba(0, 0, 0, 0.35);
                    border-radius: 6px;
                    padding: 0.05rem 0.3rem;
                }

                .cm-player-chip {
                    position: absolute;
                    transform: translate(-50%, -50%);
                    background: #0c1633;
                    border: 1px solid #5a79c4;
                    border-radius: 10px;
                    min-width: 68px;
                    padding: 0.28rem 0.35rem;
                    text-align: center;
                    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.3);
                    cursor: grab;
                }

                .cm-player-chip:active {
                    cursor: grabbing;
                }

                .cm-player-chip-readonly {
                    cursor: default;
                }

                .cm-player-chip-number {
                    display: inline-block;
                    min-width: 22px;
                    border-radius: 12px;
                    background: var(--cm-primary);
                    color: #04111d;
                    font-weight: 800;
                    font-size: 0.8rem;
                    line-height: 1.3;
                    margin-bottom: 0.15rem;
                    padding: 0 0.35rem;
                }

                .cm-player-chip-name {
                    display: block;
                    font-size: 0.7rem;
                    font-weight: 600;
                    line-height: 1.2;
                    max-width: 72px;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    white-space: nowrap;
                    margin: 0 auto;
                }

                .cm-player-chip-pos {
                    display: block;
                    font-size: 0.7rem;
                    color: #b8caf5;
                    line-height: 1.2;
                }

                .cm-row-titulaire > td {
                    background-color: rgba(185, 255, 214, 0.42) !important;
                }

                .cm-row-remplacant > td {
                    background-color: rgba(255, 228, 170, 0.44) !important;
                }

                .cm-row-absent > td {
                    background-color: rgba(255, 210, 222, 0.44) !important;
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg cm-navbar mb-4">
            <div class="container">
                <a class="navbar-brand cm-brand text-white" href="{{ path('app_home') }}">
                    <span class="cm-brand-mark">Coach</span>Manager
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto gap-lg-2">
                        <li class="nav-item"><a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'app_team' ? 'fw-bold' : '' }}" href="{{ path('app_team_index') }}">Equipes</a></li>
                        <li class="nav-item"><a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'app_player' ? 'fw-bold' : '' }}" href="{{ path('app_player_index') }}">Joueurs</a></li>
                        <li class="nav-item"><a class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'app_rencontre' ? 'fw-bold' : '' }}" href="{{ path('app_rencontre_index') }}">Matchs</a></li>
                    </ul>
                </div>
            </div>
        </nav>
        <main class="container pb-5">
            {% block body %}{% endblock %}
        </main>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    </body>
</html>
