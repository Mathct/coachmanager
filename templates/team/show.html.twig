{% extends 'base.html.twig' %}

{% block title %}Equipe | CoachManager{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="cm-page-title">{{ team.nom }}</h1>
            <p class="cm-page-subtitle">Fiche equipe</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_team_index') }}" class="btn btn-outline-light">Retour</a>
            <a href="{{ path('app_team_edit', {'id': team.id}) }}" class="btn btn-primary">Modifier</a>
        </div>
    </div>

    <div class="cm-card p-4">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="cm-stat">
                    <p class="cm-soft mb-1">Nom</p>
                    <p class="h4 mb-0">{{ team.nom }}</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="cm-stat">
                    <p class="cm-soft mb-1">Type</p>
                    <p class="h4 mb-0">{{ team.type }}</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="cm-stat">
                    <p class="cm-soft mb-1">Joueurs</p>
                    <p class="h4 mb-0">{{ team.players|length }}</p>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top border-secondary-subtle">
            <h2 class="h5 mb-3">Joueurs</h2>
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle cm-table mb-0">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Prenom</th>
                            <th>Date de naissance</th>
                            <th>Sexe</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for player in team.players %}
                            <tr>
                                <td class="fw-semibold">{{ player.nom }}</td>
                                <td>{{ player.prenom }}</td>
                                <td>{{ player.dateNaissance ? player.dateNaissance|date('d/m/Y') : '-' }}</td>
                                <td>{{ player.sexe }}</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-light" href="{{ path('app_player_show', {'id': player.id}) }}">Voir</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted py-3">Aucun joueur associe a cette equipe.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top border-secondary-subtle">
            {{ include('team/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
