{{ form_start(form) }}
    <div class="row g-3 cm-team-form">
        <div class="col-md-7">
            <div class="mb-3">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control cm-input'}}) }}
                {{ form_errors(form.nom) }}
            </div>
        </div>
        <div class="col-md-5">
            <div class="mb-3">
                {{ form_label(form.type) }}
                {{ form_widget(form.type, {'attr': {'class': 'form-control cm-input'}}) }}
                {{ form_errors(form.type) }}
            </div>
        </div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-success">{{ button_label|default('Enregistrer') }}</button>
        <a href="{{ path('app_team_index') }}" class="btn btn-outline-light">Annuler</a>
    </div>
{{ form_end(form) }}
