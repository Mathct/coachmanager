{% extends 'base.html.twig' %}

{% block title %}Rencontre{% endblock %}

{% block body %}
    <h1>Rencontre</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ rencontre.id }}</td>
            </tr>
            <tr>
                <th>Opponent</th>
                <td>{{ rencontre.opponent }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ rencontre.date ? rencontre.date|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Score_team</th>
                <td>{{ rencontre.scoreTeam }}</td>
            </tr>
            <tr>
                <th>Score_opponent</th>
                <td>{{ rencontre.scoreOpponent }}</td>
            </tr>
            <tr>
                <th>Analyse</th>
                <td>{{ rencontre.analyse }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_rencontre_index') }}">back to list</a>

    <a href="{{ path('app_rencontre_edit', {'id': rencontre.id}) }}">edit</a>

    {{ include('rencontre/_delete_form.html.twig') }}
{% endblock %}
