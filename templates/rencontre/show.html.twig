{% extends 'base.html.twig' %}

{% block title %}Match | CoachManager{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="cm-page-title">{{ rencontre.team.nom }} vs {{ rencontre.opponent }}</h1>
            <p class="cm-page-subtitle">Fiche de rencontre</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_rencontre_index') }}" class="btn btn-outline-light">Retour</a>
            <a href="{{ path('app_rencontre_composition', {'id': rencontre.id}) }}" class="btn btn-success">Composition</a>
            <a href="{{ path('app_rencontre_edit', {'id': rencontre.id}) }}" class="btn btn-primary">Modifier</a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="cm-stat h-100 text-center">
                <p class="cm-soft mb-1">Date</p>
                <p class="h5 mb-0">{{ rencontre.date ? rencontre.date|date('d/m/Y H:i') : '-' }}</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="cm-stat h-100 text-center">
                <p class="cm-soft mb-1">Score</p>
                <p class="h3 mb-0">
                    {% if rencontre.scoreTeam is not null and rencontre.scoreOpponent is not null %}
                        {{ rencontre.scoreTeam }} - {{ rencontre.scoreOpponent }}
                    {% else %}
                        A jouer
                    {% endif %}
                </p>
            </div>
        </div>
    </div>

    {% set composition = rencontre.composition %}
    {% if composition and composition.isValidated %}
        <div class="cm-card p-4 mb-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Composition</h2>
            </div>
            {% set titulaires = composition.compositionPlayers|filter(entry => entry.status == 'titulaire') %}
            {% set titulairesPlaces = titulaires|filter(entry => entry.placed) %}
            {% set remplacants = composition.compositionPlayers|filter(entry => entry.status == 'remplacant') %}
            {% set absents = composition.compositionPlayers|filter(entry => entry.status == 'absent') %}
            <p class="cm-soft mb-2">Formation: <span class="text-white fw-semibold">{{ composition.formation }}</span></p>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="cm-stat py-3">
                        <p class="cm-soft mb-1">Titulaires</p>
                        <p class="h4 mb-0">{{ titulaires|length }}</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="cm-stat py-3">
                        <p class="cm-soft mb-1">Remplacants</p>
                        <p class="h4 mb-0">{{ remplacants|length }}</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="cm-stat py-3">
                        <p class="cm-soft mb-1">Absents</p>
                        <p class="h4 mb-0">{{ absents|length }}</p>
                    </div>
                </div>
            </div>
            <div
                class="mt-3"
                data-controller="composition-field"
                data-composition-field-readonly-value="true"
            >
                <input type="hidden" data-composition-field-target="formation" value="{{ composition.formation }}">
                {% for entry in titulairesPlaces %}
                    <div
                        data-composition-field-target="row"
                        data-player-id="{{ entry.player.id }}"
                        data-player-name="{{ entry.player.nom }}"
                        hidden
                    >
                        <input data-role="status" value="{{ entry.status }}">
                        <input data-role="position" value="{{ entry.positionCode }}">
                        <input data-role="number" value="{{ entry.jerseyNumber }}">
                        <input data-role="coord-x" value="{{ entry.coordX }}">
                        <input data-role="coord-y" value="{{ entry.coordY }}">
                        <input data-role="placed" value="1">
                    </div>
                {% endfor %}
                <div class="cm-pitch cm-pitch-sm">
                    <div class="cm-pitch-center-line"></div>
                    <div class="cm-pitch-center-circle"></div>
                    <div class="cm-pitch-box cm-pitch-box-top"></div>
                    <div class="cm-pitch-box cm-pitch-box-bottom"></div>
                    <div class="cm-pitch-board" data-composition-field-target="board"></div>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="cm-card p-4">
        <h2 class="h5">Analyse</h2>
        <p class="mb-0">{{ rencontre.analyse ?: 'Aucune analyse enregistree.' }}</p>
        <div class="mt-4 pt-3 border-top border-secondary-subtle">
            {{ include('rencontre/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
