{% extends 'base.html.twig' %}

{% block title %}Composition | CoachManager{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="cm-page-title">Composition: {{ rencontre.team.nom }} vs {{ rencontre.opponent }}</h1>
            <p class="cm-page-subtitle">Definis titulaires, remplacants, absents, postes et numeros.</p>
        </div>
        <a href="{{ path('app_rencontre_show', {id: rencontre.id}) }}" class="btn btn-outline-light">Retour au match</a>
    </div>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} mb-3">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <form
        method="post"
        data-controller="composition-field"
    >
        <input type="hidden" name="_token" value="{{ csrf_token('composition' ~ rencontre.id) }}">
        <div class="row g-3">
            <div class="col-lg-7">
                <div class="cm-card p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Feuille de match</h2>
                        <span class="badge text-bg-primary" data-composition-field-target="counter">0/11 titulaires</span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label" for="formation">Formation</label>
                            <select
                                id="formation"
                                name="formation"
                                class="form-select"
                                data-composition-field-target="formation"
                                data-action="change->composition-field#onFormationChange"
                            >
                                {% for formation in formations %}
                                    <option value="{{ formation }}" {{ composition.formation == formation ? 'selected' : '' }}>{{ formation }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <p class="cm-soft mb-0">Utilise "Placer" pour ajouter un joueur au terrain, puis deplace-le si besoin.</p>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-dark align-middle cm-table mb-0">
                            <thead>
                                <tr>
                                    <th>Joueur</th>
                                    <th>Statut</th>
                                    <th>Poste</th>
                                    <th>N°</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for player in players %}
                                    {% set entry = entriesByPlayerId[player.id] %}
                                    {% set statusValue = compositionSaved ? entry.status : '' %}
                                    {% set positionValue = compositionSaved ? entry.positionCode : '' %}
                                    {% set numberValue = compositionSaved ? entry.jerseyNumber : '' %}
                                    {% set coordXValue = compositionSaved ? entry.coordX : '' %}
                                    {% set coordYValue = compositionSaved ? entry.coordY : '' %}
                                    {% set placedValue = compositionSaved and entry.placed ? '1' : '0' %}
                                    <tr
                                        data-composition-field-target="row"
                                        data-player-id="{{ player.id }}"
                                        data-player-name="{{ player.prenom }} {{ player.nom }}"
                                    >
                                        <td class="fw-semibold">{{ player.prenom }} {{ player.nom }}</td>
                                        <td>
                                            <select
                                                name="entries[{{ player.id }}][status]"
                                                class="form-select"
                                                data-role="status"
                                                data-action="change->composition-field#refresh"
                                            >
                                                <option value="">-</option>
                                                {% for status in statuses %}
                                                    <option value="{{ status }}" {{ statusValue == status ? 'selected' : '' }}>{{ status|capitalize }}</option>
                                                {% endfor %}
                                            </select>
                                        </td>
                                        <td>
                                            <select
                                                name="entries[{{ player.id }}][position]"
                                                class="form-select"
                                                data-role="position"
                                                data-action="change->composition-field#refresh"
                                            >
                                                <option value="">-</option>
                                                {% for position in positions %}
                                                    <option value="{{ position }}" {{ positionValue == position ? 'selected' : '' }}>{{ position }}</option>
                                                {% endfor %}
                                            </select>
                                        </td>
                                        <td style="width: 120px;">
                                            <input
                                                type="number"
                                                min="1"
                                                max="99"
                                                class="form-control"
                                                name="entries[{{ player.id }}][number]"
                                                value="{{ numberValue }}"
                                                data-role="number"
                                                data-action="input->composition-field#refresh"
                                            >
                                            <input type="hidden" name="entries[{{ player.id }}][coord_x]" value="{{ coordXValue }}" data-role="coord-x">
                                            <input type="hidden" name="entries[{{ player.id }}][coord_y]" value="{{ coordYValue }}" data-role="coord-y">
                                            <input type="hidden" name="entries[{{ player.id }}][is_placed]" value="{{ placedValue }}" data-role="placed">
                                            <input type="hidden" value="" data-role="slot-index">
                                        </td>
                                        <td class="text-nowrap">
                                            <button type="button" class="btn btn-sm btn-primary" data-action="click->composition-field#placePlayer">Placer</button>
                                            <button type="button" class="btn btn-sm btn-danger" data-action="click->composition-field#removePlayer">Retirer</button>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <button class="btn btn-success">Enregistrer la composition</button>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="cm-card p-4">
                    <h2 class="h5 mb-3">Rendu visuel</h2>
                    <div class="cm-pitch">
                        <div class="cm-pitch-center-line"></div>
                        <div class="cm-pitch-center-circle"></div>
                        <div class="cm-pitch-box cm-pitch-box-top"></div>
                        <div class="cm-pitch-box cm-pitch-box-bottom"></div>
                        <div class="cm-pitch-board" data-composition-field-target="board"></div>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endblock %}
